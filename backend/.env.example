# NEKO Store backend environment variables
# Copy to backend/.env for local development.
# For Railway deployment, set these in the service's Variables panel.

# Database (provided by Railway Postgres service)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=neko_store

# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# Authentication
JWT_SECRET=your-secret-key-min-32-chars-long-for-production

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hola@nekostore.cr

# Optional: WhatsApp Integration
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_GRAPH_VERSION=v20.0

# Optional: Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

