# NEKO Store backend local environment
# Copy to backend/.env for local development.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nestDB
DB_USER=postgres
DB_PASSWORD=your_password_here

JWT_SECRET=change_me_to_a_long_random_secret
HOST=0.0.0.0
PORT=4000

# Optional: Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@nekostore.cr

# Optional: WhatsApp Cloud API for customer OTP delivery.
# Without these, OTP falls back to manual admin notification.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
