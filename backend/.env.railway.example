# Railway backend service variables
# Root Directory: backend
# Build Command: npm install
# Pre-deploy Command: npm run migrate
# Start Command: npm start

# Railway PostgreSQL reference variables.
# Rename "Postgres" if your Railway database service has a different name.
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_NAME=${{Postgres.PGDATABASE}}
DB_USER=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# Required production secret. Generate a long random value.
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Railway injects PORT. HOST must stay 0.0.0.0.
HOST=0.0.0.0
PORT=${{PORT}}

# Optional: Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@nekostore.cr

# Optional: WhatsApp Cloud API for customer OTP delivery.
# Without these, OTP falls back to manual admin notification.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
